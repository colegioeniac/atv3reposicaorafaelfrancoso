    {
      "parameters": {
        "operation": "executeQuery",
        "descriptionType": "manual",
        "toolDescription": "Cadastra um NOVO produto no estoque. Use apenas para produtos que ainda nao existem.",
        "query": "SELECT estoque_ia.cadastrar_produto($1::jsonb) AS resultado;",
        "options": {
          "queryReplacement": "={{ $fromAI('payload', \"JSON string. Campos: nome (obrigatorio), preco, quantidade, categoria, descricao, estoque_minimo. Ex: {\\\"nome\\\":\\\"Mouse Gamer\\\",\\\"preco\\\":89.90,\\\"quantidade\\\":50}\", 'string') }}"
        }
      },
      "id": "014c6bf4-932a-4ec6-a2ff-973142897d3b",
